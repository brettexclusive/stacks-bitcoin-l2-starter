NEXT_PUBLIC_STACKS_NETWORK=testnet

# Use mock mode while designing the claim UX. Set to "live" after wiring a Clarity contract call.
STACKS_CLAIM_MODE=mock

# Comma-separated Stacks addresses eligible for the MVP claim flow.
ALLOWLIST_WALLETS=

# Optional app metadata shown in the UI.
NEXT_PUBLIC_APP_NAME=sBTC Access Pass
NEXT_PUBLIC_APP_SYMBOL=SBTC
NEXT_PUBLIC_APP_IMAGE_URL=

# Required for a live contract-backed flow.
NEXT_PUBLIC_STACKS_CONTRACT_ADDRESS=
NEXT_PUBLIC_STACKS_CONTRACT_NAME=
NEXT_PUBLIC_STACKS_CONTRACT_FUNCTION=claim

# Comma-separated Stacks addresses that can unlock the local admin allowlist panel.
ADMIN_WALLETS=
